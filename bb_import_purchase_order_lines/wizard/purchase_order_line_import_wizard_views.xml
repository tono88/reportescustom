<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_line_import_wizard_form" model="ir.ui.view">
        <field name="name">purchase.order.line.import.wizard.form</field>
        <field name="model">purchase.order.line.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar líneas de OC">
                <sheet>
                    <group invisible="state != 'upload'">
                        <group>
                            <field name="purchase_id"/>
                            <field name="import_file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="has_header"/>
                            <field name="delimiter"/>
                            <field name="product_lookup"/>
                            <field name="import_mode"/>
                        </group>
                    </group>

                    <group invisible="state != 'upload'">
                        <div class="alert alert-info" role="alert">
                            <p><strong>Columnas base esperadas</strong></p>
                            <p>Producto, Descripción, Cantidad, UDM, Precio Unitario, Impuestos, Fecha de entrega.</p>
                            <p>Si el archivo tiene encabezados, también puedes agregar columnas extra usando el nombre técnico del campo al final.</p>
                            <p>Ejemplos de búsqueda de producto: referencia interna, código de barras o nombre.</p>
                            <p>Fechas recomendadas: 2026-04-07, 07/04/2026 o 07/04/2026 08:00.</p>
                        </div>
                    </group>

                    <group invisible="state != 'result'">
                        <field name="result_message" widget="html" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer invisible="state != 'upload'">
                    <button name="action_import" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
                <footer invisible="state != 'result'">
                    <button name="action_close" type="object" string="Cerrar" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
