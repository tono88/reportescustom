<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_refund_no_stock_wizard_form" model="ir.ui.view">
        <field name="name">pos.refund.no.stock.wizard.form</field>
        <field name="model">pos.refund.no.stock.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear reembolsos POS sin inventario">
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="state != 'draft'">
                        Este asistente crea una <strong>orden POS de reembolso</strong>, la deja
                        <strong>pagada</strong> y <strong>no genera movimientos de inventario</strong>.
                        La orden original no se cancela ni se modifica.
                    </div>

                    <group invisible="state != 'draft'">
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="pos_session_id"/>
                        <field name="skip_existing"/>
                    </group>

                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                        El Excel debe ser .xlsx y la <strong>primera columna</strong> debe contener la referencia POS,
                        por ejemplo el valor de <strong>Ref. de la orden / pos_reference</strong>. La primera fila puede ser encabezado.
                    </div>

                    <group invisible="state != 'done'">
                        <field name="result_message" nolabel="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_process" type="object" string="Crear y pagar reembolsos" class="btn-primary" invisible="state != 'draft'"/>
                    <button string="Cerrar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_refund_no_stock_wizard" model="ir.actions.act_window">
        <field name="name">Reembolsar POS sin inventario</field>
        <field name="res_model">pos.refund.no.stock.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_pos_refund_no_stock_wizard"
              name="Reembolsar POS sin inventario"
              parent="point_of_sale.menu_point_root"
              action="action_pos_refund_no_stock_wizard"
              sequence="95"/>
</odoo>
