<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_payment_register_form_inherit_bank_reference" model="ir.ui.view">
        <field name="name">account.payment.register.form.inherit.bank.reference</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <!-- Robust: add to first group, avoids depending on specific field names -->
            <xpath expr="//group[1]" position="inside">
                <field name="bank_reference"/>
            </xpath>
        </field>
    </record>
</odoo>
