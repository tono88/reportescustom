<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_dup_bank_reference_wizard_form" model="ir.ui.view">
        <field name="name">account.dup.bank.reference.wizard.form</field>
        <field name="model">account.dup.bank.reference.wizard</field>
        <field name="arch" type="xml">
            <form string="Referencia bancaria duplicada">
                <group>
                    <div class="alert alert-warning" role="alert">
                        <strong>Esta referencia bancaria ya está siendo usada.</strong>
                        <div>Puedes cerrar para corregirla o proseguir si es intencional.</div>
                    </div>
                    <field name="bank_reference" readonly="1"/>
                </group>

                <group string="Pagos encontrados">
                    <field name="duplicates_html" nolabel="1" readonly="1"/>
                </group>

                <footer>
                    <button name="action_proceed" type="object" string="Proseguir de todos modos" class="btn-primary"/>
                    <button string="Cerrar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
